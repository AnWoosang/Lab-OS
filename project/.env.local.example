# ─── Slack (Distributed App — 멀티 워크스페이스) ──────────────────────────────
# api.slack.com/apps → 앱 선택 → Basic Information
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ─── AI ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Supabase (Auth + Storage + 워크스페이스 DB) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# 참고: SLACK_BOT_TOKEN, NOTION_API_KEY, NOTION_DB_* 는 여기에 없습니다.
# 이 값들은 각 연구실이 온보딩 시 입력하며 Supabase workspaces 테이블에 저장됩니다.
